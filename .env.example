# ============================================================
# Family Tree API — Environment Variables Example
# Скопируй в .env и заполни реальными значениями:
#   cp .env.example .env
# ============================================================

# ── App ───────────────────────────────────────────────────
# Публичный URL фронтенда (используется в письмах для подтверждения email и сброса пароля)
APP_BASE_URL=http://your-server-ip:3000

# ── JWT ───────────────────────────────────────────────────
# Одинаковый для auth-service и tree-service
# Сгенерировать: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_64_CHARS

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── Mail (SMTP — Yandex) ──────────────────────────────────
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=587
MAIL_USERNAME=your-email@yandex.ru
MAIL_PASSWORD=your-yandex-app-password

# ── Yandex GPT AI ─────────────────────────────────────────
# API-ключ (Authorization: Api-Key <значение>)
AI_YANDEX_API_KEY=
# Folder ID каталога Yandex Cloud (console.yandex.cloud → выбрать каталог → ID в URL)
AI_YANDEX_FOLDER_ID=

# ── S3 / Yandex Object Storage ────────────────────────────
# Ключи доступа: console.yandex.cloud → Object Storage → Ключи доступа
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Имя бакета (создать в Yandex Object Storage)
S3_BUCKET=family-tree-storage
# Endpoint и регион (не менять для Yandex)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
