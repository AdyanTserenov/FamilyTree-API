# ============================================================
# Family Tree API — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real secrets.
# ============================================================

# ── JWT ───────────────────────────────────────────────────
# Must be the same for auth-service and tree-service
JWT_SECRET=mySuperSecretKeyThatIsLongEnoughForHMACSHA256Algorithm123456789

# ── Mail (SMTP) ───────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Yandex GPT AI (optional) ─────────────────────────────
# Leave blank to disable AI features gracefully
AI_YANDEX_API_KEY=
AI_YANDEX_FOLDER_ID=
